# Stop Lombok from searching parent directories for config
config.stopBubbling = true

# Propagate @Qualifier to Lombok-generated constructor parameters.
# Without this, @RequiredArgsConstructor does NOT copy @Qualifier from fields
# to constructor params, causing Spring to inject the @Primary DataSource
# (e4u_ai_filter) instead of learningDataSource (e4u_learning).
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier
